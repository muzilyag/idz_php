<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body {
            font-family: DejaVu Sans, sans-serif;
            font-size: 12px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
        }
        th, td {
            border: 1px solid #000;
            padding: 5px;
            text-align: left;
        }
    </style>
</head>
<body>
    <h2>Реестр строительных проектов</h2>
    <table>
        <thead>
            <tr>
                <th>№</th>
                <th>Название</th>
                <th>Материалы</th>
                <th>Бюджет</th>
                <th>Начало работ</th>
                <th>Срок</th>
                <th>Место</th>
            </tr>
        </thead>
        <tbody>
            {% for p in projects %}
                <tr>
                    <td>{{ loop.index }}</td>
                    <td>{{ p.projectName }}</td>
                    <td>{{ p.materials }}</td>
                    <td>{{ p.budget }}</td>
                    <td>{{ p.deadlineStart ? p.deadlineStart|date('d.m.Y') : '-' }}</td>
                    <td>{{ p.deadlineFinish ? p.deadlineFinish|date('d.m.Y') : '-' }}</td>
                    <td>{{ p.place }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</body>
</html>
